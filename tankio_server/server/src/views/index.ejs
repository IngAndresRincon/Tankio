<%- include('partials/head') -%>
    <div class="container-fluid">
        <div class="card text-center" style="width: 100%; max-width: 400px;border-radius: 10px;margin: auto;">
            
            <div style="align-items: center;">
                <img src="/img/logo-petromil-vertical.png" alt="" width="200" height="200">
            </div>
            <h5 class="mb-4 text-secondary">Por favor ingresa tus credenciales</h5>
            <form id="loginForm">
                <h5 id="idpantalla" style="display: none;"><%=idpantalla %></h5>
                <div class="form-floating mb-3">
                    
                    <!-- <input type="email" class="form-control" id="email" placeholder="Email">
                    <label for="email">Email address</label> -->
                    <input type="text" class="form-control" id="username" placeholder="User">
                    <label for="username">Usuario</label>
                </div>
                <div class="form-floating mb-3">
                    <input type="password" class="form-control" id="password" placeholder="Password">
                    <label for="password">Contraseña</label>
                </div>
                <div class="mb-3 text-end">
                    <a href="#" class="text-link">¿Olvidaste tu contraseña?</a>
                </div>
                <button type="submit" class="btn btn-login w-100" id="loginBtn">
                    <span id="loginText">Ingresar</span>
                </button>
                <!-- <p class="mt-2">Don't have an account? <a h ref="#" class="text-link">Sign up</a></p> -->
                <span class="spinner-border spinner-border-sm d-none" role="status" id="loadingSpinner"></span>
            </form>
        </div>
        <script src="/js/login.js"></script>
    </div>
